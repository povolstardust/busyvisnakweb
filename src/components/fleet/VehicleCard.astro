---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';

interface Props {
  vehicle: CollectionEntry<'fleet'>;
  lang: Lang;
}

const { vehicle, lang } = Astro.props;
const { data } = vehicle;
const slug = vehicle.id.replace(/\.md$/, '');
const t = useTranslations(lang);
const detailHref = lang === 'en' ? `/en/fleet/${slug}` : `/flotila/${slug}`;

const equipIcons = [
  { key: 'airConditioning', icon: '❄️', label: t('fleet.equipment.airConditioning') },
  { key: 'wifi', icon: '📶', label: t('fleet.equipment.wifi') },
  { key: 'usb', icon: '🔌', label: t('fleet.equipment.usb') },
  { key: 'toilet', icon: '🚽', label: t('fleet.equipment.toilet') },
  { key: 'tv', icon: '📺', label: t('fleet.equipment.tv') },
] as const;

const categoryLabels: Record<string, string> = {
  microbus: 'Mini',
  midibus: 'Midi',
  fullsize: lang === 'cs' ? 'Plnorozměrný' : 'Standard',
  luxury: lang === 'cs' ? 'Luxusní' : 'Luxury',
};
---

<article
  class="vehicle-card group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col border border-silver-200"
  data-capacity={data.capacity}
  data-category={data.category}
  data-wifi={data.equipment.wifi ? 'true' : 'false'}
  data-toilet={data.equipment.toilet ? 'true' : 'false'}
  data-ac={data.equipment.airConditioning ? 'true' : 'false'}
>
  <!-- Image -->
  <div class="relative aspect-[16/10] overflow-hidden bg-navy-800">
    <img
      src={data.coverImage}
      alt={data.name}
      width="640"
      height="400"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <!-- Category badge -->
    <div class="absolute top-3 left-3">
      <span class="badge badge-navy text-xs">{categoryLabels[data.category]}</span>
    </div>
    <!-- Capacity badge -->
    <div class="absolute top-3 right-3 bg-orange-500 text-white font-display font-bold text-sm px-3 py-1 rounded-full">
      {data.capacity} {t('fleet.capacity')}
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <h3 class="font-display font-bold text-navy-900 text-lg mb-1">{data.name}</h3>
    <p class="text-sm text-silver-400 mb-4">{data.year} · Euro {data.specs.euroNorm?.replace('Euro ', '')}</p>

    <!-- Equipment icons -->
    <div class="flex flex-wrap gap-2 mb-4">
      {equipIcons.map(({ key, icon, label }) =>
        data.equipment[key as keyof typeof data.equipment] && (
          <span title={label} class="flex items-center gap-1 text-xs bg-silver-100 text-navy-700 px-2 py-1 rounded-md">
            <span>{icon}</span>
            <span class="hidden sm:inline">{label}</span>
          </span>
        )
      )}
    </div>

    <!-- Price + CTA -->
    <div class="mt-auto flex items-center justify-between gap-3">
      {data.priceFrom && (
        <span class="text-sm font-semibold text-navy-700">{data.priceFrom}</span>
      )}
      <a href={detailHref} class="btn-outline text-sm px-4 py-2 ml-auto">
        {t('fleet.detail')} →
      </a>
    </div>
  </div>
</article>
