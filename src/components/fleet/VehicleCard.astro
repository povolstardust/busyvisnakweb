---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';

interface Props {
  vehicle: CollectionEntry<'fleet'>;
  lang: Lang;
}

const { vehicle, lang } = Astro.props;
const { data } = vehicle;
const slug = vehicle.id.replace(/\.md$/, '');
const t = useTranslations(lang);
const detailHref = lang === 'en' ? `/en/fleet/${slug}` : `/flotila/${slug}`;

const equipIcons: { key: keyof typeof data.equipment; svg: string; label: string }[] = [
  {
    key: 'airConditioning',
    label: t('fleet.equipment.airConditioning'),
    svg: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1M4.22 4.22l.707.707M18.364 18.364l.707.707M3 12h1m16 0h1M4.927 19.073l.707-.707M18.364 5.636l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>`,
  },
  {
    key: 'wifi',
    label: t('fleet.equipment.wifi'),
    svg: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.142 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>`,
  },
  {
    key: 'usb',
    label: t('fleet.equipment.usb'),
    svg: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.311V21m-3.75-2.311V21m0 0a.75.75 0 01-.75.75h-.75a.75.75 0 01-.75-.75v-.75m3 0h-3"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V3m6 3.75V3M9 6.75h6M9 6.75a1.5 1.5 0 00-1.5 1.5v2.25a1.5 1.5 0 001.5 1.5h6a1.5 1.5 0 001.5-1.5V8.25a1.5 1.5 0 00-1.5-1.5H9z"/></svg>`,
  },
  {
    key: 'toilet',
    label: t('fleet.equipment.toilet'),
    svg: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>`,
  },
  {
    key: 'tv',
    label: t('fleet.equipment.tv'),
    svg: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 20h12M9 4l3-2 3 2M4 8h16a1 1 0 011 1v8a1 1 0 01-1 1H4a1 1 0 01-1-1V9a1 1 0 011-1z"/></svg>`,
  },
];

const categoryLabels: Record<string, string> = {
  microbus: 'Mini',
  midibus: 'Midi',
  fullsize: lang === 'cs' ? 'Plnorozměrný' : 'Standard',
  luxury: lang === 'cs' ? 'Luxusní' : 'Luxury',
};
---

<article
  class="vehicle-card group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col border border-silver-200 hover:border-orange-300/50"
  data-capacity={data.capacity}
  data-category={data.category}
  data-wifi={data.equipment.wifi ? 'true' : 'false'}
  data-toilet={data.equipment.toilet ? 'true' : 'false'}
  data-ac={data.equipment.airConditioning ? 'true' : 'false'}
>
  <!-- Image -->
  <div class="relative aspect-[16/10] overflow-hidden bg-navy-800">
    <img
      src={data.coverImage}
      alt={data.name}
      width="640"
      height="400"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <!-- Gradient overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-navy-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    <!-- Category badge -->
    <div class="absolute top-3 left-3">
      <span class="badge badge-navy text-xs">{categoryLabels[data.category]}</span>
    </div>
    <!-- Capacity badge -->
    <div class="absolute top-3 right-3 bg-orange-500 text-white font-display font-bold text-sm px-3 py-1 rounded-full shadow-md">
      {data.capacity} {t('fleet.capacity')}
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <h3 class="font-display font-bold text-navy-900 text-lg mb-1 group-hover:text-orange-600 transition-colors">{data.name}</h3>
    <p class="text-xs text-silver-300 mb-4 uppercase tracking-wide font-medium">{data.year} · Euro {data.specs.euroNorm?.replace('Euro ', '')}</p>

    <!-- Equipment icons -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {equipIcons.map(({ key, svg, label }) =>
        data.equipment[key as keyof typeof data.equipment] && (
          <span title={label} class="flex items-center gap-1.5 text-xs bg-silver-50 border border-silver-200 text-navy-700 px-2.5 py-1.5 rounded-lg">
            <span class="text-orange-500" set:html={svg} />
            <span class="hidden sm:inline font-medium">{label}</span>
          </span>
        )
      )}
    </div>

    <!-- Price + CTA -->
    <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-silver-100">
      {data.priceFrom && (
        <span class="text-sm font-semibold text-navy-700">{data.priceFrom}</span>
      )}
      <a href={detailHref} class="btn-outline text-sm px-4 py-2 ml-auto group-hover:bg-navy-800 group-hover:text-white group-hover:border-navy-800 transition-colors">
        {t('fleet.detail')} →
      </a>
    </div>
  </div>
</article>
