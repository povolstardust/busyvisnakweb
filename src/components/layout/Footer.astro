---
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { company } from '@/data/company';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'en' ? '/en' : '';
const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white/70 pt-16 pb-8">
  <div class="container-wide">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-white/10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-orange-500 rounded-lg flex items-center justify-center font-display font-black text-white text-sm">
            BV
          </div>
          <div>
            <div class="font-display font-bold text-white text-base leading-tight">Busy Višňák</div>
            <div class="text-white/50 text-xs">TV-DOPRAVA s.r.o.</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-5">{t('footer.tagline')}</p>
        <div class="flex gap-3">
          <a href={company.social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/10 hover:bg-orange-500 flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href={company.social.instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/10 hover:bg-orange-500 flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider mb-4">{t('footer.quickLinks')}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}/flotila`} class="hover:text-orange-400 transition-colors">{t('nav.fleet')}</a></li>
          <li><a href={`${base}/sluzby`} class="hover:text-orange-400 transition-colors">{t('nav.services')}</a></li>
          <li><a href={`${base}/o-nas`} class="hover:text-orange-400 transition-colors">{t('nav.about')}</a></li>
          <li><a href={`${base}/blog`} class="hover:text-orange-400 transition-colors">{t('nav.blog')}</a></li>
          <li><a href={lang === 'en' ? '/en/inquiry' : '/poptavka'} class="hover:text-orange-400 transition-colors">{t('nav.cta')}</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider mb-4">{t('nav.services')}</h3>
        <ul class="space-y-2 text-sm">
          {lang === 'cs' ? (
            <>
              <li><a href="/sluzby/skolni-vylety" class="hover:text-orange-400 transition-colors">Školní výlety</a></li>
              <li><a href="/sluzby/firemni-doprava" class="hover:text-orange-400 transition-colors">Firemní doprava</a></li>
              <li><a href="/sluzby/svatby" class="hover:text-orange-400 transition-colors">Svatební převozy</a></li>
              <li><a href="/sluzby/mezinarodni-doprava" class="hover:text-orange-400 transition-colors">Mezinárodní doprava</a></li>
            </>
          ) : (
            <>
              <li><a href="/en/services/school-trips" class="hover:text-orange-400 transition-colors">School Trips</a></li>
              <li><a href="/en/services/corporate-transport" class="hover:text-orange-400 transition-colors">Corporate Transport</a></li>
              <li><a href="/en/services/weddings" class="hover:text-orange-400 transition-colors">Wedding Transport</a></li>
              <li><a href="/en/services/international" class="hover:text-orange-400 transition-colors">International Tours</a></li>
            </>
          )}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider mb-4">{t('contact.title')}</h3>
        <address class="not-italic text-sm space-y-3">
          <div class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>{company.address.street}<br />{company.address.zip} {company.address.city}</span>
          </div>
          <div class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="hover:text-white transition-colors">{company.phone}</a>
          </div>
          <div class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href={`mailto:${company.email}`} class="hover:text-white transition-colors">{company.email}</a>
          </div>
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <span>{t('footer.copyright').replace('2025', String(year))}</span>
      <div class="flex gap-4">
        <a href={`${base}/gdpr`} class="hover:text-white/70 transition-colors">{t('footer.privacy')}</a>
        <a href={`${base}/cookies`} class="hover:text-white/70 transition-colors">{t('footer.cookies')}</a>
      </div>
    </div>
  </div>
</footer>
