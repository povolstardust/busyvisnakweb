---
import type { Lang } from '@/i18n/utils';
import { useTranslations, getTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const tr = getTranslations(lang);
const apiEndpoint = '/api/poptavka';

const steps = lang === 'cs'
  ? [{ n: 1, label: 'Trasa & datum' }, { n: 2, label: 'Kontaktní údaje' }, { n: 3, label: 'Odeslat' }]
  : [{ n: 1, label: 'Route & date' }, { n: 2, label: 'Contact info' }, { n: 3, label: 'Submit' }];
---

<!-- Step indicator -->
<div class="flex items-center gap-0 mb-8" id="step-indicator" aria-label="Kroky formuláře">
  {steps.map((s, i) => (
    <>
      <div class="flex flex-col items-center gap-1.5 flex-1">
        <div
          id={`step-dot-${s.n}`}
          class={`w-9 h-9 rounded-full flex items-center justify-center text-sm font-display font-bold border-2 transition-all duration-300 ${
            s.n === 1 ? 'bg-orange-500 border-orange-500 text-white shadow-md shadow-orange-500/30' : 'bg-white border-silver-200 text-silver-300'
          }`}
        >
          <span id={`step-num-${s.n}`}>{s.n}</span>
          <svg id={`step-check-${s.n}`} class="hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <span id={`step-label-${s.n}`} class={`text-xs font-medium transition-colors duration-300 hidden sm:block ${s.n === 1 ? 'text-orange-500' : 'text-silver-300'}`}>{s.label}</span>
      </div>
      {i < steps.length - 1 && (
        <div class="flex-1 h-0.5 mx-1 mb-5 sm:mb-6 overflow-hidden bg-silver-200 rounded-full">
          <div id={`step-line-${s.n}`} class="h-full bg-orange-400 rounded-full transition-all duration-500 w-0"></div>
        </div>
      )}
    </>
  ))}
</div>

<form
  id="inquiry-form"
  class="space-y-6"
  novalidate
  data-lang={lang}
  data-api={apiEndpoint}
>
  <!-- Honeypot -->
  <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <!-- STEP 1: Route & date -->
  <div id="form-step-1">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="from" class="form-label">{t('inquiry.from')} <span class="text-red-500">*</span></label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-silver-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2M2 12h2m16 0h2"/></svg>
          </span>
          <input type="text" id="from" name="from" class="form-input pl-9" placeholder={t('inquiry.fromPlaceholder')} required />
        </div>
        <p class="form-error hidden" id="from-error"></p>
      </div>
      <div>
        <label for="to" class="form-label">{t('inquiry.to')} <span class="text-red-500">*</span></label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-silver-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </span>
          <input type="text" id="to" name="to" class="form-input pl-9" placeholder={t('inquiry.toPlaceholder')} required />
        </div>
        <p class="form-error hidden" id="to-error"></p>
      </div>
      <div>
        <label for="date" class="form-label">{t('inquiry.date')} <span class="text-red-500">*</span></label>
        <input type="date" id="date" name="date" class="form-input" required min={new Date().toISOString().split('T')[0]} />
        <p class="form-error hidden" id="date-error"></p>
      </div>
      <div>
        <label for="returnDate" class="form-label">{t('inquiry.returnDate')}</label>
        <input type="date" id="returnDate" name="returnDate" class="form-input" />
      </div>
      <div>
        <label for="passengers" class="form-label">{t('inquiry.passengers')} <span class="text-red-500">*</span></label>
        <div class="flex rounded-xl border-2 border-silver-200 overflow-hidden focus-within:border-orange-500 transition-colors bg-white">
          <button type="button" id="passengers-minus" class="w-12 bg-silver-50 hover:bg-silver-100 text-navy-700 font-bold text-xl flex items-center justify-center transition-colors border-r border-silver-200" aria-label="Méně">−</button>
          <input type="number" id="passengers" name="passengers" class="flex-1 text-center border-none outline-none bg-white font-semibold text-navy-900 py-3" value="20" min="1" max="100" required />
          <button type="button" id="passengers-plus" class="w-12 bg-silver-50 hover:bg-silver-100 text-navy-700 font-bold text-xl flex items-center justify-center transition-colors border-l border-silver-200" aria-label="Více">+</button>
        </div>
        <p class="form-error hidden" id="passengers-error"></p>
      </div>
      <div>
        <label class="form-label">{t('inquiry.eventType')} <span class="text-red-500">*</span></label>
        <div class="grid grid-cols-2 gap-2" role="radiogroup">
          {Object.entries(tr.inquiry.eventTypes).map(([val, label]) => (
            <label class="flex items-center gap-2 p-2.5 border-2 border-silver-200 rounded-xl cursor-pointer hover:border-orange-400 has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50 transition-all text-sm">
              <input type="radio" name="eventType" value={val} class="accent-orange-500" required />
              <span class="font-medium text-navy-800">{label}</span>
            </label>
          ))}
        </div>
        <p class="form-error hidden" id="eventType-error"></p>
      </div>
    </div>

    <div class="flex justify-end mt-6">
      <button type="button" id="next-to-step2" class="btn-cta px-8 py-3">
        {lang === 'cs' ? 'Pokračovat' : 'Continue'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- STEP 2: Contact -->
  <div id="form-step-2" class="hidden">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      <div>
        <label for="name" class="form-label">{t('inquiry.name')} <span class="text-red-500">*</span></label>
        <input type="text" id="name" name="name" class="form-input" placeholder={t('inquiry.namePlaceholder')} required autocomplete="name" />
        <p class="form-error hidden" id="name-error"></p>
      </div>
      <div>
        <label for="phone" class="form-label">{t('inquiry.phone')} <span class="text-red-500">*</span></label>
        <input type="tel" id="phone" name="phone" class="form-input" placeholder={t('inquiry.phonePlaceholder')} required autocomplete="tel" />
        <p class="form-error hidden" id="phone-error"></p>
      </div>
      <div>
        <label for="email" class="form-label">{t('inquiry.email')} <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" class="form-input" placeholder={t('inquiry.emailPlaceholder')} required autocomplete="email" />
        <p class="form-error hidden" id="email-error"></p>
      </div>
    </div>

    <div class="mt-5">
      <label for="message" class="form-label">{t('inquiry.message')}</label>
      <textarea id="message" name="message" class="form-input min-h-[100px] resize-y" placeholder={t('inquiry.messagePlaceholder')} rows="4"></textarea>
    </div>

    <div class="flex items-start gap-3 mt-5">
      <input type="checkbox" id="gdpr" name="gdpr" class="mt-1 w-4 h-4 accent-orange-500 shrink-0" required />
      <label for="gdpr" class="text-sm text-silver-400 cursor-pointer leading-relaxed">
        {t('inquiry.gdprConsent')}
      </label>
    </div>
    <p class="form-error hidden" id="gdpr-error"></p>

    <div class="flex gap-3 mt-6">
      <button type="button" id="back-to-step1" class="btn-outline px-6 py-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        {lang === 'cs' ? 'Zpět' : 'Back'}
      </button>
      <button type="submit" id="submit-btn" class="btn-cta flex-1 justify-center text-base py-3.5">
        <span id="submit-text">{t('inquiry.submit')}</span>
        <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
      </button>
    </div>
  </div>
</form>

<!-- Success -->
<div id="form-success" class="hidden bg-green-50 border border-green-200 rounded-2xl p-8 text-center">
  <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 shadow-md shadow-green-200">
    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
  </div>
  <h3 class="font-display font-bold text-green-800 text-xl mb-2">{t('inquiry.successTitle')}</h3>
  <p class="text-green-700 text-sm leading-relaxed">{t('inquiry.successText')}</p>
</div>

<div id="form-error-msg" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700">
  {t('inquiry.errorText')}
</div>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  const step1 = document.getElementById('form-step-1');
  const step2 = document.getElementById('form-step-2');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitText = document.getElementById('submit-text');
  const submitSpinner = document.getElementById('submit-spinner');
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error-msg');
  const lang = form?.dataset.lang ?? 'cs';

  // Passenger stepper
  const passInput = document.getElementById('passengers') as HTMLInputElement | null;
  document.getElementById('passengers-minus')?.addEventListener('click', () => {
    if (passInput) passInput.value = String(Math.max(1, Number(passInput.value) - 1));
  });
  document.getElementById('passengers-plus')?.addEventListener('click', () => {
    if (passInput) passInput.value = String(Math.min(100, Number(passInput.value) + 1));
  });

  // Step indicator helper
  function setStep(n: number) {
    [1, 2, 3].forEach(s => {
      const dot = document.getElementById(`step-dot-${s}`);
      const label = document.getElementById(`step-label-${s}`);
      const num = document.getElementById(`step-num-${s}`);
      const check = document.getElementById(`step-check-${s}`);
      const line = document.getElementById(`step-line-${s}`);

      if (!dot || !label) return;

      if (s < n) {
        // completed
        dot.className = dot.className.replace(/bg-white|bg-orange-500|border-silver-200|border-orange-500|text-silver-300|text-white|shadow-md shadow-orange-500\/30/g, '').trim();
        dot.classList.add('bg-green-500', 'border-green-500', 'text-white');
        label.classList.remove('text-silver-300', 'text-orange-500');
        label.classList.add('text-green-600');
        num?.classList.add('hidden');
        check?.classList.remove('hidden');
        if (line) line.style.width = '100%';
      } else if (s === n) {
        // active
        dot.className = dot.className.replace(/bg-white|bg-green-500|border-silver-200|border-green-500|text-silver-300|text-green-500/g, '').trim();
        dot.classList.add('bg-orange-500', 'border-orange-500', 'text-white', 'shadow-md', 'shadow-orange-500/30');
        label.classList.remove('text-silver-300', 'text-green-600');
        label.classList.add('text-orange-500');
        num?.classList.remove('hidden');
        check?.classList.add('hidden');
      } else {
        // future
        dot.className = dot.className.replace(/bg-orange-500|bg-green-500|border-orange-500|border-green-500|text-white|shadow-md shadow-orange-500\/30|shadow-md|shadow-orange-500\/30/g, '').trim();
        dot.classList.add('bg-white', 'border-silver-200', 'text-silver-300');
        label.classList.remove('text-orange-500', 'text-green-600');
        label.classList.add('text-silver-300');
        num?.classList.remove('hidden');
        check?.classList.add('hidden');
      }
    });
  }

  // Validation helpers
  const msgs = {
    required: lang === 'cs' ? 'Toto pole je povinné' : 'This field is required',
    email: lang === 'cs' ? 'Zadejte platný e-mail' : 'Please enter a valid email',
    phone: lang === 'cs' ? 'Zadejte platný telefon' : 'Please enter a valid phone number',
    gdpr: lang === 'cs' ? 'Souhlas je povinný' : 'Consent is required',
    eventType: lang === 'cs' ? 'Vyberte typ akce' : 'Please select an event type',
  };

  function showError(id: string, msg: string) {
    const el = document.getElementById(`${id}-error`);
    const input = document.getElementById(id) as HTMLInputElement | null;
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
    if (input) input.classList.add('error');
  }

  function clearErrors() {
    document.querySelectorAll('.form-error').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.form-input').forEach(el => el.classList.remove('error'));
  }

  function validateStep1(): boolean {
    clearErrors();
    let valid = true;
    const fields = [
      { id: 'from', check: (v: string) => v.trim().length > 0, msg: msgs.required },
      { id: 'to', check: (v: string) => v.trim().length > 0, msg: msgs.required },
      { id: 'date', check: (v: string) => v.trim().length > 0, msg: msgs.required },
      { id: 'passengers', check: (v: string) => Number(v) >= 1, msg: msgs.required },
    ];
    for (const { id, check, msg } of fields) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && !check(el.value)) { showError(id, msg); valid = false; }
    }
    const eventType = form?.querySelector<HTMLInputElement>('input[name="eventType"]:checked');
    if (!eventType) {
      const el = document.getElementById('eventType-error');
      if (el) { el.textContent = msgs.eventType; el.classList.remove('hidden'); }
      valid = false;
    }
    return valid;
  }

  function validateStep2(): boolean {
    clearErrors();
    let valid = true;
    const fields = [
      { id: 'name', check: (v: string) => v.trim().length >= 2, msg: msgs.required },
      { id: 'phone', check: (v: string) => /^[\d\s+\-()]{7,}$/.test(v), msg: msgs.phone },
      { id: 'email', check: (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v), msg: msgs.email },
    ];
    for (const { id, check, msg } of fields) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && !check(el.value)) { showError(id, msg); valid = false; }
    }
    const gdpr = document.getElementById('gdpr') as HTMLInputElement | null;
    if (gdpr && !gdpr.checked) { showError('gdpr', msgs.gdpr); valid = false; }
    return valid;
  }

  // Step navigation
  document.getElementById('next-to-step2')?.addEventListener('click', () => {
    if (!validateStep1()) return;
    step1?.classList.add('hidden');
    step2?.classList.remove('hidden');
    setStep(2);
    window.scrollTo({ top: (form?.getBoundingClientRect().top ?? 0) + window.scrollY - 120, behavior: 'smooth' });
  });

  document.getElementById('back-to-step1')?.addEventListener('click', () => {
    step2?.classList.add('hidden');
    step1?.classList.remove('hidden');
    setStep(1);
  });

  // Submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateStep2()) return;
    if (!submitBtn || !submitText || !submitSpinner) return;

    setStep(3);
    submitBtn.disabled = true;
    submitText.textContent = lang === 'cs' ? 'Odesílám...' : 'Sending...';
    submitSpinner.classList.remove('hidden');
    errorDiv?.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const res = await fetch(form.dataset.api ?? '/api/poptavka', { method: 'POST', body: formData });
      if (res.ok) {
        form.classList.add('hidden');
        document.getElementById('step-indicator')?.classList.add('hidden');
        successDiv?.classList.remove('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      setStep(2);
      errorDiv?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitText.textContent = lang === 'cs' ? 'Odeslat poptávku' : 'Send Inquiry';
      submitSpinner.classList.add('hidden');
    }
  });
</script>
