---
import type { Lang } from '@/i18n/utils';
import { useTranslations, getTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const tr = getTranslations(lang);
const apiEndpoint = '/api/poptavka';
---

<form
  id="inquiry-form"
  class="space-y-6"
  novalidate
  data-lang={lang}
  data-api={apiEndpoint}
>
  <!-- Honeypot (hidden from real users) -->
  <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <!-- From -->
    <div>
      <label for="from" class="form-label">{t('inquiry.from')} <span class="text-red-500">*</span></label>
      <input type="text" id="from" name="from" class="form-input" placeholder={t('inquiry.fromPlaceholder')} required />
      <p class="form-error hidden" id="from-error"></p>
    </div>
    <!-- To -->
    <div>
      <label for="to" class="form-label">{t('inquiry.to')} <span class="text-red-500">*</span></label>
      <input type="text" id="to" name="to" class="form-input" placeholder={t('inquiry.toPlaceholder')} required />
      <p class="form-error hidden" id="to-error"></p>
    </div>
    <!-- Date -->
    <div>
      <label for="date" class="form-label">{t('inquiry.date')} <span class="text-red-500">*</span></label>
      <input type="date" id="date" name="date" class="form-input" required min={new Date().toISOString().split('T')[0]} />
      <p class="form-error hidden" id="date-error"></p>
    </div>
    <!-- Return date -->
    <div>
      <label for="returnDate" class="form-label">{t('inquiry.returnDate')}</label>
      <input type="date" id="returnDate" name="returnDate" class="form-input" />
    </div>
    <!-- Passengers -->
    <div>
      <label for="passengers" class="form-label">{t('inquiry.passengers')} <span class="text-red-500">*</span></label>
      <div class="flex rounded-lg border-2 border-silver-200 overflow-hidden focus-within:border-orange-500 transition-colors">
        <button type="button" id="passengers-minus" class="w-12 bg-silver-100 hover:bg-silver-200 text-navy-800 font-bold text-xl flex items-center justify-center transition-colors" aria-label="Méně">−</button>
        <input type="number" id="passengers" name="passengers" class="flex-1 text-center border-none outline-none bg-white font-semibold text-navy-900 py-2.5" value="20" min="1" max="100" required />
        <button type="button" id="passengers-plus" class="w-12 bg-silver-100 hover:bg-silver-200 text-navy-800 font-bold text-xl flex items-center justify-center transition-colors" aria-label="Více">+</button>
      </div>
      <p class="form-error hidden" id="passengers-error"></p>
    </div>
    <!-- Event type -->
    <div>
      <label class="form-label">{t('inquiry.eventType')} <span class="text-red-500">*</span></label>
      <div class="grid grid-cols-2 gap-2" role="radiogroup">
        {Object.entries(tr.inquiry.eventTypes).map(([val, label]) => (
          <label class="flex items-center gap-2 p-2.5 border-2 border-silver-200 rounded-lg cursor-pointer hover:border-orange-400 has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50 transition-all">
            <input type="radio" name="eventType" value={val} class="accent-orange-500" required />
            <span class="text-sm font-medium text-navy-800">{label}</span>
          </label>
        ))}
      </div>
      <p class="form-error hidden" id="eventType-error"></p>
    </div>
  </div>

  <!-- Contact info -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
    <div>
      <label for="name" class="form-label">{t('inquiry.name')} <span class="text-red-500">*</span></label>
      <input type="text" id="name" name="name" class="form-input" placeholder={t('inquiry.namePlaceholder')} required autocomplete="name" />
      <p class="form-error hidden" id="name-error"></p>
    </div>
    <div>
      <label for="phone" class="form-label">{t('inquiry.phone')} <span class="text-red-500">*</span></label>
      <input type="tel" id="phone" name="phone" class="form-input" placeholder={t('inquiry.phonePlaceholder')} required autocomplete="tel" />
      <p class="form-error hidden" id="phone-error"></p>
    </div>
    <div>
      <label for="email" class="form-label">{t('inquiry.email')} <span class="text-red-500">*</span></label>
      <input type="email" id="email" name="email" class="form-input" placeholder={t('inquiry.emailPlaceholder')} required autocomplete="email" />
      <p class="form-error hidden" id="email-error"></p>
    </div>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="form-label">{t('inquiry.message')}</label>
    <textarea id="message" name="message" class="form-input min-h-[100px] resize-y" placeholder={t('inquiry.messagePlaceholder')} rows="4"></textarea>
  </div>

  <!-- GDPR -->
  <div class="flex items-start gap-3">
    <input type="checkbox" id="gdpr" name="gdpr" class="mt-1 w-4 h-4 accent-orange-500 shrink-0" required />
    <label for="gdpr" class="text-sm text-silver-400 cursor-pointer">
      {t('inquiry.gdprConsent')}
    </label>
  </div>
  <p class="form-error hidden" id="gdpr-error"></p>

  <!-- Submit -->
  <button type="submit" id="submit-btn" class="btn-cta w-full justify-center text-base py-4">
    <span id="submit-text">{t('inquiry.submit')}</span>
    <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
    </svg>
  </button>
</form>

<!-- Success / error messages -->
<div id="form-success" class="hidden bg-green-50 border border-green-200 rounded-xl p-6 text-center">
  <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
  </div>
  <h3 class="font-display font-bold text-green-800 text-lg mb-1">{t('inquiry.successTitle')}</h3>
  <p class="text-green-700 text-sm">{t('inquiry.successText')}</p>
</div>

<div id="form-error-msg" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700">
  {t('inquiry.errorText')}
</div>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitText = document.getElementById('submit-text');
  const submitSpinner = document.getElementById('submit-spinner');
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error-msg');
  const lang = form?.dataset.lang ?? 'cs';

  // Passenger stepper
  const passInput = document.getElementById('passengers') as HTMLInputElement | null;
  document.getElementById('passengers-minus')?.addEventListener('click', () => {
    if (passInput) passInput.value = String(Math.max(1, Number(passInput.value) - 1));
  });
  document.getElementById('passengers-plus')?.addEventListener('click', () => {
    if (passInput) passInput.value = String(Math.min(100, Number(passInput.value) + 1));
  });

  // Validation helpers
  const msgs = {
    required: lang === 'cs' ? 'Toto pole je povinné' : 'This field is required',
    email: lang === 'cs' ? 'Zadejte platný e-mail' : 'Please enter a valid email',
    phone: lang === 'cs' ? 'Zadejte platný telefon' : 'Please enter a valid phone number',
    gdpr: lang === 'cs' ? 'Souhlas je povinný' : 'Consent is required',
    eventType: lang === 'cs' ? 'Vyberte typ akce' : 'Please select an event type',
  };

  function showError(id: string, msg: string) {
    const el = document.getElementById(`${id}-error`);
    const input = document.getElementById(id) as HTMLInputElement | null;
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
    if (input) input.classList.add('error');
  }

  function clearErrors() {
    document.querySelectorAll('.form-error').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.form-input').forEach(el => el.classList.remove('error'));
  }

  function validate(): boolean {
    clearErrors();
    let valid = true;
    const fields: { id: string; check: (v: string) => boolean; msg: string }[] = [
      { id: 'from', check: v => v.trim().length > 0, msg: msgs.required },
      { id: 'to', check: v => v.trim().length > 0, msg: msgs.required },
      { id: 'date', check: v => v.trim().length > 0, msg: msgs.required },
      { id: 'passengers', check: v => Number(v) >= 1, msg: msgs.required },
      { id: 'name', check: v => v.trim().length >= 2, msg: msgs.required },
      { id: 'phone', check: v => /^[\d\s+\-()]{7,}$/.test(v), msg: msgs.phone },
      { id: 'email', check: v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v), msg: msgs.email },
    ];
    for (const { id, check, msg } of fields) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && !check(el.value)) { showError(id, msg); valid = false; }
    }
    const eventType = form?.querySelector<HTMLInputElement>('input[name="eventType"]:checked');
    if (!eventType) {
      const el = document.getElementById('eventType-error');
      if (el) { el.textContent = msgs.eventType; el.classList.remove('hidden'); }
      valid = false;
    }
    const gdpr = document.getElementById('gdpr') as HTMLInputElement | null;
    if (gdpr && !gdpr.checked) { showError('gdpr', msgs.gdpr); valid = false; }
    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validate()) return;
    if (!submitBtn || !submitText || !submitSpinner) return;

    submitBtn.disabled = true;
    submitText.textContent = lang === 'cs' ? 'Odesílám...' : 'Sending...';
    submitSpinner.classList.remove('hidden');
    errorDiv?.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const res = await fetch(form.dataset.api ?? '/api/poptavka', {
        method: 'POST',
        body: formData,
      });
      if (res.ok) {
        form.classList.add('hidden');
        successDiv?.classList.remove('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorDiv?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitText.textContent = lang === 'cs' ? 'Odeslat poptávku' : 'Send Inquiry';
      submitSpinner.classList.add('hidden');
    }
  });
</script>
