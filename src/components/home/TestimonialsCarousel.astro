---
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { testimonials } from '@/data/testimonials';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section-pad bg-navy-900 text-white">
  <div class="container-wide">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="section-title text-white mb-3">{t('testimonials.title')}</h2>
      <p class="text-white/60">{t('testimonials.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map((item) => (
        <div class="bg-navy-800 rounded-2xl p-6 flex flex-col gap-4">
          <!-- Stars -->
          <div class="flex gap-0.5">
            {[...Array(item.rating)].map(() => (
              <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <!-- Quote -->
          <blockquote class="text-white/80 text-sm leading-relaxed flex-1">
            "{item.text}"
          </blockquote>
          <!-- Author -->
          <div class="flex items-center gap-3 pt-2 border-t border-white/10">
            <div class="w-9 h-9 rounded-full bg-orange-500/20 flex items-center justify-center text-orange-400 font-display font-bold text-sm shrink-0">
              {item.name.charAt(0)}
            </div>
            <div>
              <p class="text-white font-semibold text-sm leading-tight">{item.name}</p>
              <p class="text-white/50 text-xs">{item.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
