---
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { company } from '@/data/company';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const inquiryHref = lang === 'en' ? '/en/inquiry' : '/poptavka';
---

<section class="bg-gradient-to-r from-orange-500 to-orange-600 text-white py-16">
  <div class="container-wide">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
      <div class="text-center lg:text-left max-w-xl">
        <h2 class="font-display font-black text-3xl md:text-4xl mb-3">{t('ctaBanner.headline')}</h2>
        <p class="text-white/85 text-lg">{t('ctaBanner.subheading')}</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 shrink-0">
        <a href={inquiryHref} class="inline-flex items-center gap-2 px-6 py-3.5 bg-white text-orange-600 font-display font-bold rounded-lg hover:bg-orange-50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {t('ctaBanner.cta')}
        </a>
        <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-2 px-6 py-3.5 bg-orange-700/40 text-white font-display font-bold rounded-lg hover:bg-orange-700/60 transition-colors border border-white/30">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {t('ctaBanner.phone')}
        </a>
      </div>
    </div>
  </div>
</section>
