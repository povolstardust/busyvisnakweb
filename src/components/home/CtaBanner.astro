---
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { company } from '@/data/company';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const inquiryHref = lang === 'en' ? '/en/inquiry' : '/poptavka';
---

<section class="relative bg-orange-500 text-white py-20 overflow-hidden">
  <!-- Decorative circles -->
  <div class="absolute -top-20 -right-20 w-72 h-72 bg-orange-400/40 rounded-full blur-2xl pointer-events-none"></div>
  <div class="absolute -bottom-16 -left-16 w-56 h-56 bg-orange-600/50 rounded-full blur-2xl pointer-events-none"></div>
  <!-- Dot pattern overlay -->
  <div class="absolute inset-0 opacity-[0.08]" style="background-image: radial-gradient(circle, white 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
  <!-- Diagonal stripe accent -->
  <div class="absolute top-0 right-0 bottom-0 w-1/3 bg-gradient-to-l from-orange-600/30 to-transparent pointer-events-none hidden lg:block"></div>

  <div class="relative container-wide">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-10">
      <div class="text-center lg:text-left max-w-xl reveal">
        <!-- Icon -->
        <div class="inline-flex items-center justify-center w-14 h-14 bg-white/15 rounded-2xl mb-5 lg:mb-4">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h2 class="font-display font-black text-3xl md:text-4xl mb-3 leading-tight">{t('ctaBanner.headline')}</h2>
        <p class="text-white/80 text-lg leading-relaxed">{t('ctaBanner.subheading')}</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 shrink-0 reveal reveal-delay-2">
        <a href={inquiryHref} class="inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-white text-orange-600 font-display font-bold rounded-xl hover:bg-orange-50 transition-colors shadow-xl shadow-orange-700/25">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {t('ctaBanner.cta')}
        </a>
        <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-orange-600/50 text-white font-display font-bold rounded-xl hover:bg-orange-700/60 transition-colors border border-white/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {t('ctaBanner.phone')}
        </a>
      </div>
    </div>
  </div>
</section>
