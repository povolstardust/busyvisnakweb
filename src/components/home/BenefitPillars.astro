---
import type { Lang } from '@/i18n/utils';
import { useTranslations, getTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const tr = getTranslations(lang);

const icons: Record<string, string> = {
  shield: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  snowflake: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18M5.636 5.636l12.728 12.728M18.364 5.636L5.636 18.364"/></svg>`,
  star: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
  globe: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
};
---

<section class="section-pad bg-white">
  <div class="container-wide">
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <h2 class="section-title mb-3">{t('benefits.title')}</h2>
      <p class="section-subtitle mx-auto">{t('benefits.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {tr.benefits.items.map((item, i) => (
        <div class={`group relative p-7 rounded-2xl bg-silver-50 border border-silver-100 hover:border-orange-400/40 hover:shadow-lg hover:shadow-orange-500/8 transition-all duration-300 flex flex-col gap-5 reveal reveal-delay-${i + 1}`}>
          <!-- Orange accent bar top -->
          <div class="absolute top-0 left-6 right-6 h-0.5 rounded-b-full bg-orange-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

          <div class="w-14 h-14 rounded-xl bg-orange-500/10 group-hover:bg-orange-500/18 text-orange-500 flex items-center justify-center transition-colors duration-300"
               set:html={icons[item.icon]}
          />
          <div>
            <h3 class="font-display font-bold text-navy-900 text-lg mb-2 leading-snug">
              {item.title}
            </h3>
            <p class="text-silver-400 text-sm leading-relaxed">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
