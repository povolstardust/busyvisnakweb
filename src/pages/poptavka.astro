---
import BaseLayout from '@/layouts/BaseLayout.astro';
import InquiryForm from '@/components/inquiry/InquiryForm.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'cs';
const t = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  title={`${t('inquiry.title')} | TV-DOPRAVA Busy Višňák`}
  description={t('inquiry.subtitle')}
>
  <!-- Page header -->
  <section class="bg-navy-900 text-white py-16">
    <div class="container-wide">
      <div class="max-w-xl">
        <span class="badge mb-4">{lang === 'cs' ? 'Odpovíme do 24 hodin' : 'Reply within 24 hours'}</span>
        <h1 class="section-title text-white mb-4">{t('inquiry.title')}</h1>
        <p class="section-subtitle text-white/70">{t('inquiry.subtitle')}</p>
      </div>
    </div>
  </section>

  <section class="section-pad bg-silver-50">
    <div class="container-wide">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-silver-200">
            <InquiryForm lang={lang} />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Why us box -->
          <div class="bg-navy-900 text-white rounded-2xl p-6">
            <h2 class="font-display font-bold text-lg mb-4">Proč si vybrat nás?</h2>
            <ul class="space-y-3 text-sm text-white/80">
              {[
                '30 let na trhu, stovky spokojených zákazníků',
                'Moderní vozový park s kompletní výbavou',
                'Zkušení a proškolení řidiči',
                'Přesná dochvilnost a spolehlivost',
                'Fakturace na IČO pro firmy',
                'Pojištění pasažérů',
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-orange-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <!-- Contact box -->
          <div class="bg-white rounded-2xl p-6 border border-silver-200">
            <h2 class="font-display font-bold text-navy-900 text-base mb-4">Nebo nás kontaktujte přímo</h2>
            <div class="space-y-3 text-sm">
              <a href="tel:+420475123456" class="flex items-center gap-3 text-navy-800 hover:text-orange-600 transition-colors font-medium">
                <div class="w-9 h-9 bg-orange-100 rounded-lg flex items-center justify-center text-orange-500">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                +420 475 123 456
              </a>
              <a href="mailto:info@tv-doprava.cz" class="flex items-center gap-3 text-navy-800 hover:text-orange-600 transition-colors font-medium">
                <div class="w-9 h-9 bg-orange-100 rounded-lg flex items-center justify-center text-orange-500">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                info@tv-doprava.cz
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
