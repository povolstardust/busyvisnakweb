---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'cs';
const t = useTranslations(lang);

const timeline = [
  { year: 1994, event: 'Založení firmy TV-DOPRAVA panem Višňákem v Ústí nad Labem. Start s jedním mikrobusem.' },
  { year: 2000, event: 'Rozšíření vozového parku na 5 vozidel. První mezinárodní zájezdy do Německa a Rakouska.' },
  { year: 2008, event: 'Investice do prvních plnorozměrných autobusů. Zahájení pravidelné spolupráce se školami.' },
  { year: 2015, event: 'Modernizace celého vozového parku. Certifikace kvality ISO. Rozšíření do Německa.' },
  { year: 2020, event: 'Přechod na Euro 6 vozidla. Zavedení WiFi a USB nabíjení do všech nových autobusů.' },
  { year: 2024, event: '30 let na trhu. Flotila 8+ vozidel, 15 zaměstnanců, stovky spokojených zákazníků ročně.' },
];
---

<BaseLayout
  lang={lang}
  title="O nás | TV-DOPRAVA Busy Višňák — 30 let autobusové dopravy"
  description="Rodinná firma TV-DOPRAVA Busy Višňák z Ústí nad Labem. 30 let zkušeností v autobusové dopravě. Zkušení řidiči, moderní vozový park, bezpečnost na prvním místě."
>
  <!-- Hero -->
  <section class="bg-navy-900 text-white py-16">
    <div class="container-wide max-w-2xl">
      <span class="badge mb-4">Od roku 1994</span>
      <h1 class="section-title text-white mb-4">{t('about.title')}</h1>
      <p class="section-subtitle text-white/70">{t('about.subtitle')}</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-orange-500 text-white py-10">
    <div class="container-wide">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { num: '30+', label: 'let zkušeností' },
          { num: '8+', label: 'vozidel ve flotile' },
          { num: '15', label: 'zaměstnanců' },
          { num: '500+', label: 'cest ročně' },
        ].map(({ num, label }) => (
          <div>
            <div class="font-display font-black text-4xl md:text-5xl">{num}</div>
            <div class="text-white/80 text-sm mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-pad bg-white">
    <div class="container-wide max-w-3xl">
      <h2 class="section-title mb-12 text-center">{t('about.historyTitle')}</h2>
      <div class="relative">
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-silver-200"></div>
        <div class="space-y-8">
          {timeline.map(({ year, event }) => (
            <div class="relative flex gap-6 pl-16">
              <div class="absolute left-0 w-12 h-12 rounded-full bg-orange-500 text-white flex items-center justify-center font-display font-bold text-xs text-center leading-tight">
                {year}
              </div>
              <div class="flex-1 pb-2">
                <p class="text-navy-800 leading-relaxed">{event}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Safety & certifications -->
  <section class="section-pad bg-silver-50">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-title mb-6">{t('about.safetyTitle')}</h2>
          <div class="space-y-4 text-navy-800 leading-relaxed">
            <p>Bezpečnost cestujících je naší nejvyšší prioritou. Každé vozidlo prochází pravidelnou technickou kontrolou a servisní prohlídkou dle předepsaných intervalů.</p>
            <p>Všichni naši řidiči jsou držiteli profesního průkazu způsobilosti (Průkaz řidiče profesionála) a absolvují pravidelná školení v oblasti bezpečné jízdy a první pomoci.</p>
            <p>Naše vozidla jsou vybavena moderními bezpečnostními systémy — ABS, ESP, adaptivní tempomat a bezpečnostní pásy na každém místě.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            {
              svg: `<svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
              title: 'Technická kontrola',
              desc: 'Pravidelné STK a servisní prohlídky',
            },
            {
              svg: `<svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>`,
              title: 'Průkaz způsobilosti',
              desc: 'Všichni řidiči s profesním průkazem',
            },
            {
              svg: `<svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
              title: 'První pomoc',
              desc: 'Školení řidičů v první pomoci',
            },
            {
              svg: `<svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285zm0 13.5h.008v.008H12v-.008z"/></svg>`,
              title: 'Pojištění',
              desc: 'Komplexní pojištění vozidel i pasažérů',
            },
          ].map(({ svg, title, desc }) => (
            <div class="bg-white rounded-xl p-5 border border-silver-200">
              <div class="mb-3"><Fragment set:html={svg} /></div>
              <h3 class="font-display font-bold text-navy-900 text-sm mb-1">{title}</h3>
              <p class="text-silver-400 text-xs">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad bg-navy-900 text-white">
    <div class="container-wide text-center max-w-lg mx-auto">
      <h2 class="font-display font-bold text-3xl mb-4">Pojďme spolupracovat</h2>
      <p class="text-white/70 mb-8">Rádi vám připravíme nabídku přesně na míru vašim potřebám.</p>
      <a href="/poptavka" class="btn-cta text-base px-8 py-4">Nezávazná poptávka</a>
    </div>
  </section>
</BaseLayout>
