---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, getTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const tr = getTranslations(lang);

const serviceLinks: Record<string, string> = {
  'school-trips': '/en/services/school-trips',
  'corporate-transport': '/en/services/corporate-transport',
  'weddings': '/en/services/weddings',
  'international': '/en/services/international',
};
const icons: Record<string, string> = {
  'graduation-cap': `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>`,
  'briefcase': `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  'heart': `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
  'plane': `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>`,
};
---

<BaseLayout lang={lang} title="Our Services | TV-DOPRAVA Busy Višňák" description="Coach hire for school trips, corporate events, weddings and international tours. Ústí nad Labem, Czech Republic.">
  <section class="bg-navy-900 text-white py-16">
    <div class="container-wide max-w-2xl">
      <h1 class="section-title text-white mb-4">{t('services.title')}</h1>
      <p class="section-subtitle text-white/70">{t('services.subtitle')}</p>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {tr.services.items.map(service => (
          <a href={serviceLinks[service.slug] ?? '#'} class="group flex flex-col gap-5 p-8 rounded-2xl border-2 border-silver-200 hover:border-orange-500 hover:shadow-xl transition-all duration-300">
            <div class="w-20 h-20 rounded-2xl bg-orange-500/10 text-orange-500 group-hover:bg-orange-500 group-hover:text-white flex items-center justify-center transition-all" set:html={icons[service.icon]} />
            <div>
              <h2 class="font-display font-bold text-navy-900 text-2xl mb-2">{service.title}</h2>
              <p class="text-silver-400 leading-relaxed">{service.short}</p>
            </div>
            <div class="text-orange-500 font-semibold flex items-center gap-1 mt-auto">{t('services.learnMore')} →</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
