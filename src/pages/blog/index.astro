---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n/utils';

const lang = 'cs';
const t = useTranslations(lang);
const posts = (await getCollection('blog', ({ data }) => data.lang === 'cs'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  lang={lang}
  title="Blog — Tipy pro cestování | TV-DOPRAVA Busy Višňák"
  description="Tipy na školní výlety, firemní doprava, novinky z firmy. Blog TV-DOPRAVA Busy Višňák Ústí nad Labem."
>
  <section class="bg-navy-900 text-white py-16">
    <div class="container-wide max-w-2xl">
      <h1 class="section-title text-white mb-4">{t('blog.title')}</h1>
      <p class="section-subtitle text-white/70">{t('blog.subtitle')}</p>
    </div>
  </section>

  <section class="section-pad bg-silver-50">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <a href={`/blog/${post.id.replace(/^cs\//, '').replace(/\.md$/, '')}`} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow flex flex-col border border-silver-200">
            {post.data.image && (
              <div class="aspect-[16/9] bg-navy-800 overflow-hidden">
                <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} width="640" height="360" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
            )}
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="badge badge-silver">{post.data.category}</span>
                <span class="text-silver-400 text-xs">{post.data.readTime} {t('blog.minRead')}</span>
              </div>
              <h2 class="font-display font-bold text-navy-900 text-lg leading-snug mb-2 group-hover:text-orange-600 transition-colors">{post.data.title}</h2>
              <p class="text-silver-400 text-sm leading-relaxed flex-1">{post.data.description}</p>
              <div class="mt-4 text-sm text-silver-300">
                {post.data.pubDate.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' })}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
