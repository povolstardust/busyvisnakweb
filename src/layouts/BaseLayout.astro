---
import Navigation from '@/components/layout/Navigation.astro';
import Footer from '@/components/layout/Footer.astro';
import SEOHead from '@/components/layout/SEOHead.astro';
import type { Lang } from '@/i18n/utils';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  class?: string;
  heroPage?: boolean;
}

const { title, description, lang, ogImage, canonicalUrl, noindex, class: className, heroPage } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang === 'cs' ? 'cs' : 'en'} class="scroll-smooth">
  <head>
    <SEOHead
      title={title}
      description={description}
      lang={lang}
      ogImage={ogImage}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
    />
  </head>
  <body class={className} data-hero={heroPage ? 'true' : undefined}>
    <Navigation lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
